# App
PRINTVAULT_ENV=development
PRINTVAULT_LOG_LEVEL=INFO
PRINTVAULT_BIND_HOST=0.0.0.0
PRINTVAULT_BIND_PORT=8080

# Database: use DATABASE_URL_FILE in Docker. SQLite is supported for local dev/tests.
PRINTVAULT_DATABASE_URL=sqlite:///./printvault.sqlite3
PRINTVAULT_DATABASE_URL_FILE=

# OIDC: mandatory in deployed environments; no local password login exists.
PRINTVAULT_OIDC_ISSUER_URL=https://nextcloud.example.invalid/apps/oidc
PRINTVAULT_OIDC_CLIENT_ID=printvault
PRINTVAULT_OIDC_AUDIENCE=printvault
PRINTVAULT_OIDC_GROUPS_CLAIM=groups

# Writable libraries: comma-separated absolute paths inside the container.
PRINTVAULT_LIBRARY_MODELS_ROOT=/libraries/modelle
PRINTVAULT_LIBRARY_PROJECTS_ROOT=/libraries/projekte
PRINTVAULT_LIBRARY_ARCHIVE_ROOT=/libraries/archiv
PRINTVAULT_DATA_ROOT=/data
PRINTVAULT_THUMBNAILS_ROOT=/thumbnails

# Viewer and helper limits
PRINTVAULT_VIEWER_MAX_BYTES=104857600
PRINTVAULT_HELPER_URL_TTL_SECONDS=60
