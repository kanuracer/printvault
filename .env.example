# Runtime
PRINTVAULT_ENVIRONMENT=production
PRINTVAULT_PORT=8080
PRINTVAULT_IMAGE=printvault:local
PRINTVAULT_CONTAINER_NAME=printvault

# OIDC is mandatory in production. Replace all example values before starting.
PRINTVAULT_OIDC_ISSUER_URL=https://id.example.com
PRINTVAULT_OIDC_REDIRECT_URI=https://printvault.example.com/api/auth/callback
PRINTVAULT_OIDC_GROUPS_CLAIM=groups

# Host directories mounted by compose.yaml. Keep generated data and secrets out of Git.
PRINTVAULT_MODELS_DIR=./models
PRINTVAULT_ARCHIVE_DIR=./archive
PRINTVAULT_DATA_DIR=./data
PRINTVAULT_THUMBNAILS_DIR=./thumbnails
PRINTVAULT_SECRETS_DIR=./secrets

# Container paths. Do not change unless the matching compose mounts change too.
PRINTVAULT_LIBRARY_MODELS_ROOT=/libraries/models
PRINTVAULT_LIBRARY_ARCHIVE_ROOT=/libraries/archive
PRINTVAULT_DATA_ROOT=/var/lib/printvault
PRINTVAULT_THUMBNAILS_ROOT=/var/lib/printvault/thumbnails
